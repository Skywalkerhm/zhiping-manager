# 环境变量配置示例
# 复制此文件为 .env 并填写真实值

# ==================== 应用配置 ====================
APP_NAME=智评管家
APP_ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-here-please-change-in-production
API_PREFIX=/api/v1

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=zhiping_manager
DB_USER=root
DB_PASSWORD=your-password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== JWT 配置 ====================
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== LLM API 配置 ====================
# 通义千问（阿里云）
QWEN_API_KEY=sk-your-qwen-api-key
QWEN_MODEL_DEFAULT=qwen-turbo

# 文心一言（百度）
ERNIE_API_KEY=your-ernie-api-key
ERNIE_SECRET_KEY=your-ernie-secret-key
ERNIE_MODEL_DEFAULT=ernie-bot-4

# 腾讯混元
HUNYUAN_API_KEY=your-hunyuan-api-key
HUNYUAN_SECRET_KEY=your-hunyuan-secret-key

# OpenAI（可选）
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# ==================== 微信配置 ====================
WECHAT_APP_ID=your-wechat-app-id
WECHAT_APP_SECRET=your-wechat-app-secret
WECHAT_TEMPLATE_ID_NOTICE=your-template-id

# ==================== 短信配置 ====================
SMS_PROVIDER=aliyun
SMS_ACCESS_KEY_ID=your-sms-access-key
SMS_ACCESS_KEY_SECRET=your-sms-secret
SMS_SIGN_NAME=智评管家
SMS_TEMPLATE_CODE=SMS_123456789

# ==================== 对象存储配置 ====================
OSS_PROVIDER=aliyun
OSS_ACCESS_KEY_ID=your-oss-access-key
OSS_ACCESS_KEY_SECRET=your-oss-secret
OSS_BUCKET=zhiping-files
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ==================== 监控配置 ====================
PROMETHEUS_ENABLED=True
PROMETHEUS_PORT=9090

# ==================== 限流配置 ====================
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_DAY=10000

# ==================== 其他配置 ====================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
